{
  "name": "fit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/run-next-with-dist-dir.mjs build --dist-dir=.next --webpack",
    "build:test": "node scripts/run-next-with-dist-dir.mjs build --dist-dir=.next --webpack",
    "start": "next start",
    "start:test": "node scripts/run-next-with-dist-dir.mjs start --dist-dir=.next --hostname 127.0.0.1 --port 3100",
    "smoke:server": "npm run start:test",
    "lint": "eslint src next.config.ts eslint.config.mjs postcss.config.mjs",
    "typecheck": "node scripts/typecheck-stable.mjs",
    "verify:migrations": "powershell -ExecutionPolicy Bypass -File scripts/verify-migrations.ps1",
    "verify:advisors": "powershell -ExecutionPolicy Bypass -File scripts/verify-advisors.ps1",
    "verify:codex": "node scripts/verify-codex.mjs",
    "verify:agent-governance": "node scripts/verify-agent-governance.mjs",
    "verify:android-twa": "node scripts/verify-android-twa.mjs",
    "verify:runtime-env": "node scripts/verify-runtime-env.mjs",
    "verify:supabase-runtime": "node scripts/verify-supabase-runtime.mjs",
    "verify:retrieval-release": "node scripts/verify-retrieval-release.mjs",
    "agent:inventory": "node scripts/agent-inventory.mjs --out output/codex-runs/agent-evolution/latest/agent-inventory.json",
    "agent:sync-registry": "node scripts/sync-codex-agent-registry.mjs --write",
    "agent:evaluate": "node scripts/agent-evolve.mjs",
    "agent:evolve": "node scripts/agent-evolve.mjs --write",
    "agent:evolve:push": "node scripts/agent-evolve.mjs --write --push",
    "pretest:e2e": "node scripts/ensure-next-build.mjs",
    "pretest:e2e:auth": "node scripts/ensure-next-build.mjs",
    "pretest:ai-gate": "node scripts/ensure-next-build.mjs",
    "pretest:billing-gate": "node scripts/ensure-next-build.mjs",
    "pretest:sentry-gate": "node scripts/ensure-next-build.mjs",
    "pretest:smoke": "node scripts/ensure-next-build.mjs",
    "test:rls": "node scripts/run-playwright.mjs PLAYWRIGHT_SKIP_AUTH_SETUP=1 PLAYWRIGHT_BASE_URL=http://127.0.0.1:1 -- test tests/rls --workers=1",
    "test:e2e": "playwright test --workers=2",
    "test:e2e:auth": "playwright test tests/e2e --workers=2",
    "test:ai-gate": "node scripts/run-playwright.mjs -- test tests/ai-gate --workers=1",
    "test:billing-gate": "node scripts/run-playwright.mjs PLAYWRIGHT_SKIP_AUTH_SETUP=1 -- test tests/billing-gate --workers=1",
    "test:billing-gate:cloudpayments-mock": "node scripts/run-cloudpayments-mock-gate.mjs",
    "test:retrieval-gate": "node scripts/run-playwright.mjs PLAYWRIGHT_SKIP_AUTH_SETUP=1 PLAYWRIGHT_BASE_URL=http://127.0.0.1:1 -- test tests/ai-gate/hybrid-retrieval.spec.ts tests/ai-gate/knowledge-document-metadata.spec.ts tests/ai-gate/knowledge-chunk-sync.spec.ts tests/ai-gate/retrieval-metrics.spec.ts tests/ai-gate/retrieval-rollout.spec.ts tests/ai-gate/retrieval-telemetry.spec.ts tests/ai-gate/retrieval-performance.spec.ts tests/rls/retrieval-history.spec.ts --workers=1",
    "test:sentry-gate": "node scripts/run-playwright.mjs -- test tests/sentry-gate --workers=1",
    "verify:staging-runtime": "node scripts/verify-staging-runtime.mjs",
    "verify:sentry-runtime": "node scripts/verify-sentry-runtime.mjs",
    "test:smoke": "node scripts/run-playwright.mjs PLAYWRIGHT_SKIP_AUTH_SETUP=1 -- test tests/smoke"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^1.0.34",
    "@ai-sdk/react": "^2.0.152",
    "@sentry/nextjs": "^10.42.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "ai": "^5.0.150",
    "clsx": "^2.1.1",
    "dexie": "^4.3.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "streamdown": "^2.4.0",
    "stripe": "^20.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
