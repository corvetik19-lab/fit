{
  "name": "fit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/run-next-with-dist-dir.mjs build --webpack",
    "build:test": "node scripts/run-next-with-dist-dir.mjs build --webpack --dist-dir=.next_build",
    "start": "next start",
    "start:test": "node scripts/run-next-with-dist-dir.mjs start --hostname 127.0.0.1 --port 3100 --dist-dir=.next_build",
    "smoke:server": "npm run start:test",
    "lint": "eslint src next.config.ts eslint.config.mjs postcss.config.mjs",
    "typecheck": "node scripts/run-next-with-dist-dir.mjs typegen --dist-dir=.next_build && npx tsc -p tsconfig.json --noEmit --incremental false",
    "pretest:e2e": "npm run build:test",
    "pretest:e2e:auth": "npm run build:test",
    "pretest:smoke": "npm run build:test",
    "test:rls": "node scripts/run-playwright.mjs PLAYWRIGHT_SKIP_AUTH_SETUP=1 PLAYWRIGHT_BASE_URL=http://127.0.0.1:1 -- test tests/rls --workers=1",
    "test:e2e": "playwright test --workers=2",
    "test:e2e:auth": "playwright test tests/e2e --workers=2",
    "test:smoke": "node scripts/run-playwright.mjs PLAYWRIGHT_SKIP_AUTH_SETUP=1 -- test tests/smoke"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^1.0.34",
    "@ai-sdk/react": "^2.0.152",
    "@sentry/nextjs": "^10.42.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "ai": "^5.0.150",
    "clsx": "^2.1.1",
    "dexie": "^4.3.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "streamdown": "^2.4.0",
    "stripe": "^20.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
